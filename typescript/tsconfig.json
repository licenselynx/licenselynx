{
    "compilerOptions": {
        "target": "ES2017",
        "module": "nodenext",
        "outDir": "./dist",
        "rootDir": "./",
        "strict": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "declaration": true,
        "moduleResolution": "nodenext",
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["index.ts"],
    "exclude": ["node_modules", "dist", "**/*.spec.ts"]
}
